### 通用配置文件 ###
CONFIG_DEVEL=y
CONFIG_TARGET_OPTIONS=y
# 【修正】改回 -O2 保证稳定
CONFIG_TARGET_OPTIMIZATION="-O2 -pipe -march=armv8-a+crypto+crc -mcpu=cortex-a53+crypto+crc -mtune=cortex-a53"

CONFIG_CCACHE=y
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_LUCI_LANG_zh_Hant=y

# CONFIG_FEED_nss_packages is not set
# CONFIG_FEED_sqm_scripts_nss is not set
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set

CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y
# CONFIG_KERNEL_ZRAM_BACKEND_LZO is not set
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y

# 【修正】只保留必要工具，去掉 btop, ariang 等
CONFIG_PACKAGE_tmux=y
CONFIG_PACKAGE_dmesg=y
CONFIG_PACKAGE_htop=y
# CONFIG_PACKAGE_btop is not set
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_tune2fs=y
# CONFIG_PACKAGE_ariang is not set
CONFIG_PACKAGE_fstrim=y
CONFIG_PACKAGE_nano-full=y
CONFIG_PACKAGE_autocore=y
# CONFIG_PACKAGE_coremark is not set
CONFIG_PACKAGE_hdparm=y
CONFIG_PACKAGE_smartmontools-drivedb=y
CONFIG_PACKAGE_zoneinfo-asia=y
# CONFIG_PACKAGE_acme-acmesh-dnsapi is not set
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
# CONFIG_PACKAGE_sqm-scripts-nss is not set

# 【修正】去掉所有第三方主题，使用默认主题最稳
# CONFIG_PACKAGE_luci-theme-aurora is not set
# CONFIG_PACKAGE_luci-app-aurora-config is not set
# CONFIG_PACKAGE_luci-theme-argon is not set
# CONFIG_PACKAGE_luci-app-argon-config is not set

# 【修正】去掉不需要的插件 (源码已删或影响稳定)
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
# CONFIG_PACKAGE_luci-app-wolplus is not set
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
# CONFIG_PACKAGE_luci-app-aria2 is not set
CONFIG_PACKAGE_luci-app-autoreboot=y
# CONFIG_PACKAGE_luci-app-wifischedule is not set
CONFIG_PACKAGE_luci-app-uhttpd=y
# CONFIG_PACKAGE_luci-app-frps is not set
# CONFIG_PACKAGE_luci-app-frpc is not set
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-hd-idle=y
# CONFIG_PACKAGE_luci-app-banip is not set
CONFIG_PACKAGE_luci-app-acme=y
CONFIG_PACKAGE_luci-app-arpbind=y
# CONFIG_PACKAGE_luci-app-usb-printer is not set
# CONFIG_PACKAGE_luci-app-oaf is not set
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-proto-wireguard=y
# CONFIG_PACKAGE_luci-app-wechatpush is not set
CONFIG_PACKAGE_luci-app-watchcat=y
# CONFIG_PACKAGE_luci-app-3cat is not set
# CONFIG_PACKAGE_luci-app-smartdns is not set

### PassWall 配置项 (关键修正) ###
# 【修正】彻底关闭 PassWall 1 (因为你编译的是 PW2)
# CONFIG_PACKAGE_luci-app-passwall is not set

# 【修正】启用 PassWall 2
CONFIG_PACKAGE_luci-app-passwall2=y

# PassWall 2 依赖的核心 (通常会自动选中，这里显式确认)
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_v2ray-geodata=y

# 如果你需要 PW2 的特定功能，可以在这里配置，否则保持默认即可
# 注意：PW2 的配置项前缀通常是 luci-app-passwall2_...
# 下面的旧配置项对 PW2 无效，已忽略
