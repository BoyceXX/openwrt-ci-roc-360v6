### 通用配置文件 (Nikki + DAE, NOWIFI friendly) ###

CONFIG_DEVEL=y
CONFIG_TARGET_OPTIONS=y
CONFIG_TARGET_OPTIMIZATION="-O2 -pipe -march=armv8-a+crypto+crc -mcpu=cortex-a53+crypto+crc -mtune=cortex-a53"

CONFIG_CCACHE=y
CONFIG_PACKAGE_default-settings=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_LUCI_LANG_zh_Hans=y

# CONFIG_FEED_nss_packages is not set
# CONFIG_FEED_sqm_scripts_nss is not set
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set

### ZRAM ###
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y
# CONFIG_KERNEL_ZRAM_BACKEND_LZO is not set
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y

# CONFIG_ALL_KMODS is not set

### LuCI：保留必要插件（NOWIFI 更稳） ###
CONFIG_PACKAGE_luci-app-cpufreq=y
# CONFIG_PACKAGE_luci-app-ddns is not set
# CONFIG_PACKAGE_luci-app-ttyd is not set
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-uhttpd=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-app-acme=y
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_luci-app-watchcat=y

# 明确关闭你不需要/可能引入额外依赖的
# CONFIG_PACKAGE_luci-app-wifischedule is not set
# CONFIG_PACKAGE_luci-app-wechatpush is not set
# CONFIG_PACKAGE_luci-app-banip is not set
# CONFIG_PACKAGE_luci-app-3cat is not set
# CONFIG_PACKAGE_luci-app-smartdns is not set
# CONFIG_PACKAGE_luci-app-oaf is not set
# CONFIG_PACKAGE_luci-app-usb-printer is not set
# CONFIG_PACKAGE_luci-app-frps is not set
# CONFIG_PACKAGE_luci-app-frpc is not set
# CONFIG_PACKAGE_luci-app-wolplus is not set

### =========================
### Nikki (MiHoMo) block
### =========================
CONFIG_PACKAGE_nikki=y
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-i18n-nikki-zh-cn=y

# Nikki 常用内核模块/透明代理（按你之前用法保留）
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
# CONFIG_PACKAGE_iptables-mod-tproxy is not set
# CONFIG_PACKAGE_ipset is not set

### =========================
### DAE block
### =========================
CONFIG_PACKAGE_dae=y
CONFIG_PACKAGE_daed=y
CONFIG_PACKAGE_luci-app-dae=y
CONFIG_PACKAGE_luci-i18n-dae-zh-cn=y
CONFIG_PACKAGE_dae-wing=y
CONFIG_PACKAGE_luci-app-dae-wing=y
CONFIG_PACKAGE_luci-i18n-dae-wing-zh-cn=y

### iPerf3（LuCI 图形界面）###
CONFIG_PACKAGE_iperf3=y

### CoreMark（CPU 跑分）###
CONFIG_PACKAGE_coremark=y
CONFIG_COREMARK_ENABLE_MULTITHREADING=y
CONFIG_COREMARK_NUMBER_OF_THREADS=4

# DAE geo 数据：你贴的 Makefile 明确依赖 v2ray-geoip / v2ray-geosite
CONFIG_PACKAGE_dae-geoip=y
CONFIG_PACKAGE_dae-geosite=y
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y

# DAE 包常用证书依赖（有的树是 ca-bundle，有的是 ca-certificates；选中一个即可）
CONFIG_PACKAGE_ca-bundle=y
# CONFIG_PACKAGE_ca-certificates is not set

# --- DAE eBPF/BTF 内核依赖（集中放在这里） ---
CONFIG_BPF_TOOLCHAIN_HOST=y
# CONFIG_BPF_TOOLCHAIN_NONE is not set

CONFIG_KERNEL_BPF_EVENTS=y
CONFIG_KERNEL_CGROUP_BPF=y
CONFIG_KERNEL_XDP_SOCKETS=y

CONFIG_KERNEL_DEBUG_INFO=y
CONFIG_KERNEL_DEBUG_INFO_BTF=y
CONFIG_KERNEL_DEBUG_INFO_REDUCED=y
